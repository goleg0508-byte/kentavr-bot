# Telegram Bot Token (обязательно)
BOT_TOKEN=your_telegram_bot_token_here

# Ссылки
PLATFORM_URL=https://kentavr.world/?ref=kentavrmarket
LANDING_URL=https://kentavr.world

# PostgreSQL (опционально - Railway даст автоматически)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Админы (ID через запятую)
ADMIN_IDS=123456789,987654321

# Username бота (для реферальных ссылок)
BOT_USERNAME=kentavr_bot

# Порт для health сервера
PORT=8080